{
  "name": "cura-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Cura App",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^6.3.0",
    "googleapis": "^171.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.8.0"
  },
  "private": true
}
